# ─── App Business Logic Settings ───────────────────────────────────────────────
# These values are returned by GET /api/app-config and consumed by the mobile app.
# Changing them here (and restarting the server) updates the entire app instantly,
# without a new app release.  The dashboard will expose these as editable fields
# in a future milestone.

# Price charged per working day per child (INR)
PRICE_PER_DAY_PER_CHILD=200

# Plan durations in working days
PLAN_DAYS_1_MONTH=22
PLAN_DAYS_3_MONTHS=66
PLAN_DAYS_6_MONTHS=132

# Single-child discount percentages per plan tier
DISCOUNT_SINGLE_1M=0
DISCOUNT_SINGLE_3M=5
DISCOUNT_SINGLE_6M=10

# Multi-child (>= MULTI_CHILD_THRESHOLD) discount percentages per plan tier
DISCOUNT_MULTI_1M=5
DISCOUNT_MULTI_3M=15
DISCOUNT_MULTI_6M=20

# Minimum number of children to qualify for multi-child pricing
MULTI_CHILD_THRESHOLD=2

# Price per child for a single holiday meal booking (INR)
HOLIDAY_MEAL_PRICE_PER_CHILD=200

# ─── Existing env vars (keep below) ─────────────────────────────────────────────
# NODE_ENV=development
# PORT=5000
# DB_URL=mongodb+srv://...
# JWT_SECRET=...
# EMAIL_USER=...
# EMAIL_PASS=...
